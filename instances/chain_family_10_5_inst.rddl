}

instance inst_family_10_5 {
    domain = chain_family_10_5;
    non-fluents = nf_inst_family_10_5;
    init-state {
        current_stage(s1);
        last_used_family(fam_none);
        pipeline_done = false;
    };
    max-nondef-actions = 1;
    horizon = 15; 
    discount = 1.0;
}
