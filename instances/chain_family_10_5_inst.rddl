non-fluents nf_inst_family_10_5 {
    domain = chain_family_10_5;
    objects {
        stage : { s1, s2, s3, s4, s5, s6, s7, s8, s9, s10 };
        model : { m1, m2, m3, m4, m5 };
        family: { fam_1, fam_2, fam_none };
